<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EcommerceMaui.ViewModels"
             x:Class="EcommerceMaui.Views.ProductDetailsPage"
             x:DataType="vm:ProductDetailsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <VerticalStackLayout Spacing="12"
                                 IsVisible="{Binding NotFound}">
                <Label Text="Product not found."
                       FontSize="22"
                       FontAttributes="Bold" />
                <Label Text="The product you're looking for is no longer available." />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="12"
                                 IsVisible="{Binding Product, Converter={StaticResource NotNullConverter}}">
                <Label Text="{Binding Product.Name}"
                       FontSize="28"
                       FontAttributes="Bold" />
                <Label Text="{Binding Product.Description}"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light=#555555, Dark=#BBBBBB}" />
                <Label Text="{Binding Product.Price, StringFormat='{0:C}'}"
                       FontSize="22"
                       FontAttributes="Bold" />
            </VerticalStackLayout>

            <Button Text="Back" Command="{Binding BackCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
