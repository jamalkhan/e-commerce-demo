<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EcommerceMaui.ViewModels"
             xmlns:m="clr-namespace:EcommerceMaui.Models"
             x:Class="EcommerceMaui.Views.ProductsPage"
             x:DataType="vm:ProductsViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="24" RowSpacing="12">

        <Label Grid.Row="0"
               Text="Catalog"
               FontSize="28"
               FontAttributes="Bold" />

        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}" />

        <RefreshView Grid.Row="2"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy, Mode=OneWay}">

            <CollectionView ItemsSource="{Binding Products}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No products yet."
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           IsVisible="{Binding IsNotBusy}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:Product">
                        <Border Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
                                StrokeThickness="1"
                                Padding="16"
                                Margin="0,0,0,12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="18" />
                                <Label Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#BBBBBB}" />
                                <Label Text="{Binding Price, StringFormat='{0:C}'}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Button Text="View Details"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProductsViewModel}}, Path=ViewDetailsCommand}"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
